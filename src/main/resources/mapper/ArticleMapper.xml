<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.article.ArticleMapper">

    <resultMap id="articleResultMap" type="com.example.demo.article.Article">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findAll" resultMap="articleResultMap">
        SELECT id, title, content, created_at, updated_at
        FROM articles
        ORDER BY id DESC
    </select>

    <select id="findById" resultMap="articleResultMap">
        SELECT id, title, content, created_at, updated_at
        FROM articles
        WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.example.demo.article.Article" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO articles (title, content, created_at, updated_at)
        VALUES (#{title}, #{content}, #{createdAt}, #{updatedAt})
    </insert>

    <update id="update" parameterType="com.example.demo.article.Article">
        UPDATE articles
        SET title = #{title},
            content = #{content},
            updated_at = #{updatedAt}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM articles
        WHERE id = #{id}
    </delete>

</mapper>
